# Companies House STREAMING API key (a SEPARATE credential from your REST key).
# Register one at https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_STREAM_KEY=

# Companies House Public Data API (REST) key — used to enrich PSC events with the
# real company NAME (the stream only carries the number). Optional: without it,
# events show "Company <number>". This is your standard REST API key.
COMPANIES_HOUSE_API_KEY=

# Optional: restrict CORS to the frontend origin (default: * for local dev).
BODS_STREAM_CORS_ORIGIN=http://localhost:5173

# Optional REPLAY mode: feed a captured JSON-Lines file of raw PSC events through
# the same pipeline instead of connecting live. Useful when the live stream is
# quiet (evenings/weekends) or for talk demos. Takes priority over the live key.
# e.g. a file produced by OpenCheck's capture_psc_stream.py:
# BODS_STREAM_REPLAY_FILE=/Users/you/code/opencheck/backend/data/cache/psc_stream/psc_stream_sample.jsonl
BODS_STREAM_REPLAY_FILE=
BODS_STREAM_REPLAY_RATE=2
